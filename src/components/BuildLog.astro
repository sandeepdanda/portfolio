---
// BuildLog - signature element #2 from docs/design/02-signature-interaction.md
// Shows last deployed time + commit SHA. Injected at build time.
const deployedAt = new Date();
const sha = (
  process.env.CF_PAGES_COMMIT_SHA ||
  process.env.COMMIT_REF ||
  "local"
).slice(0, 7);
const formatted = deployedAt.toISOString().replace("T", " ").slice(0, 16);
---

<div class="build-log" title={`Built ${deployedAt.toISOString()}`}>
  <span>built {formatted}</span>
  <span class="sep">·</span>
  <span>{sha}</span>
</div>

<style>
  .build-log {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }
  .sep {
    opacity: 0.5;
  }
  @media (max-width: 768px) {
    .build-log {
      font-size: 0.6875rem;
    }
  }
</style>
