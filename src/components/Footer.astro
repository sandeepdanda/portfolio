---
import { SITE, SOCIAL } from "../config";
import BuildLog from "./BuildLog.astro";
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="row">
    <div class="left">
      <span>© {year} {SITE.author}</span>
      <span class="sep">·</span>
      <a href={SOCIAL.github} target="_blank" rel="noopener noreferrer">GitHub</a>
    </div>
    <p class="thanks">
      Thanks for the wander
      <svg class="wave" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M18 11V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v0"/>
        <path d="M14 10V4a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v2"/>
        <path d="M10 10.5V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v8"/>
        <path d="M18 8a2 2 0 1 1 4 0v6a8 8 0 0 1-8 8h-2c-2.8 0-4.5-.86-5.99-2.34l-3.6-3.6a2 2 0 0 1 2.83-2.82L7 15"/>
      </svg>
    </p>
  </div>
  <BuildLog />
</footer>

<style>
  .site-footer {
    padding: 2rem 3rem 2rem 6rem;
    border-top: 1px solid var(--color-border);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    position: relative;
    z-index: 1;
  }
  .thanks {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1rem;
    color: var(--color-text);
    margin: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
  }
  .wave {
    display: inline-block;
    color: var(--color-accent);
    transition: transform 200ms ease-out;
    vertical-align: -0.25em;
  }
  .thanks:hover .wave {
    animation: wave 600ms ease-in-out;
    transform-origin: 70% 70%;
  }
  @keyframes wave {
    0%, 100% { transform: rotate(0deg); }
    25% { transform: rotate(20deg); }
    75% { transform: rotate(-15deg); }
  }
  @media (max-width: 768px) {
    .site-footer {
      padding: 1.5rem 1rem 1.5rem 2.5rem;
    }
  }
  .site-footer :global(.build-log) {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px dashed var(--color-border);
  }
  .row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .left {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .left a {
    color: var(--color-text-muted);
    text-decoration: underline;
    text-decoration-color: var(--color-border);
    text-underline-offset: 3px;
  }
  .left a:hover {
    color: var(--color-text);
  }
  .sep {
    opacity: 0.5;
  }
</style>
