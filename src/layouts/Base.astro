---
import "../styles/global.css";
import { SITE, NAV } from "../config";
import Footer from "../components/Footer.astro";
import ThemeToggle from "../components/ThemeToggle.astro";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
const pageTitle = title ? `${title} — ${SITE.name}` : SITE.title;
const pageDescription = description ?? SITE.description;
const canonical = new URL(Astro.url.pathname, SITE.url).toString();
const ogUrl = new URL(ogImage ?? "/og/home.png", SITE.url).toString();
const currentPath = Astro.url.pathname;

function isCurrent(href: string): boolean {
  if (href === "/") return currentPath === "/";
  return currentPath === href || currentPath.startsWith(href + "/");
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- OG -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogUrl} />

    <!-- Fonts. Swap to self-hosted later if you care about performance. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400;1,9..144,500&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
    />

    <!-- Theme script: run before paint to avoid flash -->
    <script is:inline>
      const stored = localStorage.getItem("theme");
      if (stored) {
        document.documentElement.dataset.theme = stored;
      }
    </script>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to main content</a>

    <!-- Signature: vertical rule down the left edge -->
    <div class="vertical-rule" aria-hidden="true"></div>

    <header class="site-header">
      <nav class="nav" aria-label="Primary">
        <a href="/" class="brand">{SITE.name}</a>
        <ul class="nav-list">
          {NAV.map((item) => (
            <li>
              <a
                href={item.href}
                class="nav-link"
                aria-current={isCurrent(item.href) ? "page" : undefined}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </header>

    <main id="main" class="main">
      <slot />
    </main>

    <Footer />
    <ThemeToggle />

    <style>
      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
        padding: 0.5rem 1rem;
        background: var(--color-accent);
        color: var(--color-bg);
        z-index: 100;
        font-weight: 500;
        border-radius: 0 0 4px 0;
      }
      .skip-link:focus {
        left: 0;
        top: 0;
      }

      .vertical-rule {
        position: fixed;
        left: 3rem;
        top: 0;
        bottom: 0;
        width: 1px;
        background: var(--color-border);
        pointer-events: none;
        z-index: 0;
      }
      @media (max-width: 768px) {
        .vertical-rule {
          left: 1rem;
        }
      }

      .site-header {
        display: flex;
        align-items: center;
        padding: 2rem 3rem 2rem 6rem;
        border-bottom: 1px solid var(--color-border);
        position: relative;
        z-index: 1;
      }
      @media (max-width: 768px) {
        .site-header {
          padding: 1.25rem 1rem 1.25rem 2.5rem;
        }
      }

      .nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 100%;
        gap: 2rem;
      }

      .brand {
        font-family: var(--font-serif);
        font-size: 1.125rem;
        font-weight: 500;
        color: var(--color-text);
        letter-spacing: -0.01em;
      }

      .nav-list {
        display: flex;
        gap: 2rem;
        list-style: none;
        margin: 0;
        padding: 0;
      }

      .nav-link {
        font-family: var(--font-serif);
        font-size: 1.0625rem;
        font-weight: 400;
        color: var(--color-text-muted);
        position: relative;
        padding: 0.25rem 0;
        transition: color 150ms ease-out;
      }
      .nav-link::after {
        content: "";
        position: absolute;
        left: 0;
        right: 0;
        bottom: -0.125rem;
        height: 1px;
        background: var(--color-accent);
        transform: scaleX(0);
        transform-origin: left center;
        transition: transform 200ms ease-out;
      }
      .nav-link:hover {
        color: var(--color-text);
      }
      .nav-link:hover::after {
        transform: scaleX(1);
      }
      .nav-link[aria-current="page"] {
        color: var(--color-text);
      }
      .nav-link[aria-current="page"]::after {
        transform: scaleX(1);
        background: var(--color-accent);
      }

      .main {
        padding: 2.5rem 3rem 5rem 6rem;
        max-width: 56rem;
        position: relative;
        z-index: 1;
      }
      @media (max-width: 768px) {
        .main {
          padding: 1.5rem 1rem 3rem 2.5rem;
        }
      }
    </style>
  </body>
</html>
