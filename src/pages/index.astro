---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import PersonSchema from "../components/PersonSchema.astro";
import { readingTime, year } from "../lib/content";

const all = await getCollection("work", (e) => e.data.status !== "draft");
const sorted = all.sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
);
const featured = sorted.find((e) => e.data.featured) ?? sorted[0];
---

<Base>
  <PersonSchema />

  <section class="hero">
    <p class="location">Seattle · Software Engineer</p>
    <h1>Sandeep <em>Danda</em></h1>
    <p class="tagline">
      I build distributed backend systems at Amazon and ship AI side
      projects in my spare time.
    </p>
  </section>

  {featured && (
    <section class="section">
      <p class="section-number">01</p>
      <h2 class="section-title">Featured</h2>
      <a href={`/work/${featured.id}`} class="feature-card">
        <div class="feature-meta">
          <span>{year(featured.data.publishedAt)}</span>
          <span class="sep">·</span>
          <span>Case study</span>
          <span class="sep">·</span>
          <span>{readingTime(featured.body ?? "")} min read</span>
        </div>
        <h3 class="feature-title">{featured.data.title}</h3>
        <p class="feature-summary">{featured.data.summary}</p>
        <span class="feature-cta">Read the case study <span class="arrow">→</span></span>
      </a>
    </section>
  )}

  <section class="section">
    <p class="section-number">{featured ? "02" : "01"}</p>
    <h2 class="section-title">About</h2>
    <p class="bio">
      I like building things with small teams, small dependencies, and
      long feedback loops. Java at work, TypeScript and Python on the
      side. I live in Seattle. When I am not working I am usually reading
      or tinkering with a side project.
    </p>
    <a href="/about" class="see-all">The longer version <span class="arrow">→</span></a>
  </section>
</Base>

<style>
  /* Hero */
  .hero {
    margin: 1.5rem 0 6rem 0;
  }
  .location {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-muted);
    margin: 0 0 2rem 0;
  }
  h1 {
    font-family: var(--font-serif);
    font-size: clamp(3rem, 9vw, 6.5rem);
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 0.95;
    margin: 0 0 1.75rem 0;
  }
  h1 em {
    font-style: italic;
    font-weight: 400;
    color: var(--color-accent);
  }
  .tagline {
    font-family: var(--font-serif);
    font-size: clamp(1.25rem, 2.2vw, 1.5rem);
    line-height: 1.45;
    color: var(--color-text);
    max-width: 36rem;
    margin: 0;
    font-weight: 400;
  }

  /* Sections */
  .section {
    position: relative;
    margin-bottom: 5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }
  .section-number {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    letter-spacing: 0.1em;
    margin: 0 0 0.25rem 0;
  }
  .section-title {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-text-muted);
    margin: 0 0 2rem 0;
  }

  /* Featured card */
  .feature-card {
    display: block;
    padding: 2rem 0;
    color: inherit;
    border-bottom: 1px solid var(--color-border);
    transition: padding-left 200ms ease-out;
  }
  .feature-card:hover {
    padding-left: 0.5rem;
  }
  .feature-card:hover .feature-title {
    color: var(--color-accent);
  }
  .feature-card:hover .arrow {
    transform: translateX(4px);
  }
  .feature-meta {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin-bottom: 0.875rem;
  }
  .feature-meta .sep {
    margin: 0 0.5rem;
    opacity: 0.5;
  }
  .feature-title {
    font-family: var(--font-serif);
    font-size: clamp(1.875rem, 4vw, 2.75rem);
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin: 0 0 0.875rem 0;
    color: var(--color-text);
    transition: color 150ms ease-out;
  }
  .feature-summary {
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    max-width: 38rem;
    margin: 0 0 1.25rem 0;
  }
  .feature-cta {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-accent);
  }

  /* Secondary CTAs */
  .see-all {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }
  .see-all:hover {
    color: var(--color-accent);
  }
  .arrow {
    display: inline-block;
    transition: transform 200ms ease-out;
  }

  /* About bio */
  .bio {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-text);
    max-width: 38rem;
    margin: 0 0 1.25rem 0;
  }
</style>
