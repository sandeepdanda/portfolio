---
import Base from "../layouts/Base.astro";

const entries = [
  {
    degree: "MS, Computer Science",
    school: "University at Buffalo, SUNY",
    url: "https://www.buffalo.edu/",
    years: "Jan 2023 – Dec 2024",
    location: "Buffalo, NY",
    gpa: "3.80 / 4.00",
  },
  {
    degree: "BTech, Information Technology",
    school: "NIT Durgapur",
    url: "https://nitdgp.ac.in/",
    years: "2016 – 2020",
    location: "Durgapur, India",
    gpa: "7.8 / 10.0",
  },
  {
    degree: "High School (Class 12)",
    school: "Narayana Junior College",
    url: "https://www.narayanajuniorcolleges.com/",
    years: "2014 – 2016",
    location: "Hyderabad, India",
    gpa: "985 / 1000",
  },
  {
    degree: "High School (Class 10)",
    school: "Aryabhatta Concept School",
    url: "https://aryabhattaschools.org/",
    years: "2014",
    location: "Thorrur, India",
    gpa: "10.0 / 10.0",
  },
];
---

<Base
  title="Education"
  description="Where I studied."
>
  <section class="hero">
    <h1>Where I <em>studied</em></h1>
    <p class="subtitle">From a small town school in Thorrur, to grad school in Buffalo, with a lot of homesickness stitched in between.</p>
  </section>

  <ul class="timeline">
    {entries.map((e) => (
      <li>
        <div class="row">
          <div class="left">
            <p class="degree">{e.degree}</p>
            {e.url ? (
              <a href={e.url} target="_blank" rel="noopener noreferrer" class="school">
                {e.school}
              </a>
            ) : (
              <span class="school plain">{e.school}</span>
            )}
          </div>
          <div class="right">
            <span>{e.years}</span>
            <span>{e.location}</span>
            {e.gpa && <span>GPA {e.gpa}</span>}
          </div>
        </div>
      </li>
    ))}
  </ul>
</Base>

<style>
  .hero {
    margin: 0 0 4rem 0;
  }
  .kicker {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-muted);
    margin: 0 0 1.5rem 0;
  }
  h1 {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 7vw, 5rem);
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 0.95;
    margin: 0;
  }
  h1 em {
    font-style: italic;
    font-weight: 400;
    color: var(--color-accent);
  }
  .subtitle {
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    max-width: 34rem;
    margin: 1.25rem 0 0 0;
  }

  .timeline {
    list-style: none;
    padding: 0;
    margin: 0;
    max-width: 48rem;
  }
  .timeline > li {
    padding: 2rem 0;
    border-bottom: 1px solid var(--color-border);
  }
  .timeline > li:last-child {
    border-bottom: none;
  }
  .row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2rem;
    align-items: baseline;
  }
  @media (max-width: 640px) {
    .row {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
  }
  .left {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .degree {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-muted);
    margin: 0;
  }
  .school {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 500;
    letter-spacing: -0.015em;
    color: var(--color-text);
    text-decoration: none;
    line-height: 1.15;
  }
  a.school:hover {
    color: var(--color-accent);
  }
  .right {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    text-align: right;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    white-space: nowrap;
  }
  @media (max-width: 640px) {
    .right {
      text-align: left;
      flex-direction: row;
      flex-wrap: wrap;
      gap: 0.5rem;
    }
  }
</style>
