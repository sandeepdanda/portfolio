---
import Base from "../layouts/Base.astro";

const entries = [
  {
    degree: "MS, Computer Science",
    school: "University at Buffalo, SUNY",
    url: "https://www.buffalo.edu/",
    years: "Jan 2023 – Dec 2024",
    location: "Buffalo, NY",
    gpa: "3.80 / 4.00",
  },
  {
    degree: "BTech, Information Technology",
    school: "NIT Durgapur",
    url: "https://nitdgp.ac.in/",
    years: "2016 – 2020",
    location: "Durgapur, India",
    gpa: "7.8 / 10.0",
  },
  {
    degree: "High School (Class 12)",
    school: "Narayana Junior College",
    url: "https://www.narayanajuniorcolleges.com/",
    years: "2014 – 2016",
    location: "Hyderabad, India",
    gpa: "985 / 1000",
  },
  {
    degree: "High School (Class 10)",
    school: "Aryabhatta Concept School",
    url: "https://aryabhattaschools.org/",
    years: "2014",
    location: "Thorrur, India",
    gpa: "10.0 / 10.0",
  },
];
---

<Base
  title="Education"
  description="Where I studied."
>
  <section class="hero">
    <h1>Where I <em>studied</em></h1>
    <p class="subtitle">From a small town school in Thorrur, to grad school in Buffalo, with a lot of homesickness stitched in between.</p>
  </section>

  <ul class="cards">
    {entries.map((e) => (
      <li>
        <a class="card" href={e.url} target="_blank" rel="noopener noreferrer">
          <span class="card-top">
            <span class="label">{e.degree}</span>
            <span class="arrow" aria-hidden="true">↗</span>
          </span>
          <span class="headline">{e.school}</span>
          <span class="meta">
            <span>{e.years}</span>
            <span aria-hidden="true">·</span>
            <span>{e.location}</span>
            {e.gpa && <><span aria-hidden="true">·</span><span>GPA {e.gpa}</span></>}
          </span>
        </a>
      </li>
    ))}
  </ul>
</Base>

<style>
  .hero { margin: 0 0 4rem 0; }
  h1 {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 7vw, 5rem);
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 0.95;
    margin: 0;
  }
  h1 em {
    font-style: italic;
    font-weight: 400;
    color: var(--color-accent);
  }
  .subtitle {
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    max-width: 34rem;
    margin: 1.25rem 0 0 0;
  }

  .cards {
    list-style: none;
    padding: 0;
    margin: 0;
    max-width: 52rem;
    display: grid;
    gap: 1rem;
  }
  .cards li { display: flex; }

  .card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    width: 100%;
    padding: 1.5rem 1.5rem 1.75rem 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    color: var(--color-text);
    text-decoration: none;
    transition:
      transform 200ms ease-out,
      border-color 200ms ease-out,
      box-shadow 200ms ease-out;
  }
  .card:hover {
    transform: translateY(-2px);
    border-color: var(--color-accent);
    box-shadow: 0 4px 24px -12px var(--color-accent);
  }
  .card:hover .arrow { transform: translate(3px, -3px); color: var(--color-accent); }
  .card:hover .headline { color: var(--color-accent); }

  .card-top {
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }
  .label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-text-muted);
  }
  .arrow {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 1rem;
    color: var(--color-text-muted);
    transition: transform 200ms ease-out, color 200ms ease-out;
  }
  .headline {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 500;
    letter-spacing: -0.015em;
    line-height: 1.1;
    color: var(--color-text);
    transition: color 150ms ease-out;
  }
  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }
</style>
