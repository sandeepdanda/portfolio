---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";

const projects = (await getCollection("projects")).sort(
  (a, b) => a.data.order - b.data.order
);
---

<Base
  title="Projects"
  description="Things I have shipped or maintain."
>
  <section class="hero">
    <p class="kicker">Projects</p>
    <h1>Things I have <em>shipped</em>.</h1>
    <p class="subtitle">A mix of side projects and coursework.</p>
  </section>

  <ul class="timeline">
    {projects.map((entry) => (
      <li>
        <div class="row">
          <div class="left">
            {entry.data.repo ? (
              <a href={entry.data.repo} target="_blank" rel="noopener noreferrer" class="name">
                {entry.data.name}
              </a>
            ) : (
              <span class="name plain">{entry.data.name}</span>
            )}
            <p class="summary">{entry.data.summary}</p>
          </div>
          <div class="right">
            {entry.data.repo && (
              <a href={entry.data.repo} target="_blank" rel="noopener noreferrer" class="link">GitHub →</a>
            )}
          </div>
        </div>
        {entry.data.tags.length > 0 && (
          <ul class="tags">
            {entry.data.tags.map((t) => <li>{t}</li>)}
          </ul>
        )}
      </li>
    ))}
  </ul>
</Base>

<style>
  .hero {
    margin: 1.5rem 0 4rem 0;
  }
  .kicker {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-muted);
    margin: 0 0 1.5rem 0;
  }
  h1 {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 7vw, 5rem);
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 0.95;
    margin: 0;
  }
  h1 em {
    font-style: italic;
    font-weight: 400;
    color: var(--color-accent);
  }
  .subtitle {
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    max-width: 34rem;
    margin: 1.25rem 0 0 0;
  }

  .timeline {
    list-style: none;
    padding: 0;
    margin: 0;
    max-width: 48rem;
  }
  .timeline > li {
    padding: 2rem 0;
    border-bottom: 1px solid var(--color-border);
  }
  .timeline > li:last-child {
    border-bottom: none;
  }
  .row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2rem;
    align-items: baseline;
  }
  @media (max-width: 640px) {
    .row {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
  }

  .kind {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-muted);
    margin: 0 0 0.25rem 0;
  }
  .status-active { color: var(--color-accent); }
  .status-archived { opacity: 0.7; }

  .name {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 500;
    letter-spacing: -0.015em;
    color: var(--color-text);
    text-decoration: none;
    line-height: 1.15;
    display: block;
    margin-bottom: 0.625rem;
  }
  .name:hover {
    color: var(--color-accent);
  }
  .summary {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    margin: 0;
    max-width: 32rem;
  }

  .right {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-align: right;
    white-space: nowrap;
  }
  @media (max-width: 640px) {
    .right {
      text-align: left;
      flex-direction: row;
      flex-wrap: wrap;
      gap: 1rem;
    }
  }
  .link {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }
  .link:hover {
    color: var(--color-accent);
  }

  .tags {
    list-style: none;
    padding: 0;
    margin: 1.25rem 0 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .tags li {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    padding: 0.25rem 0.625rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
  }
</style>
