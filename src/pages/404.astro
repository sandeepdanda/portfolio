---
import Base from "../layouts/Base.astro";
---

<Base title="Not found" description="That page does not exist here.">
  <section class="wrap">
    <p class="code">404</p>
    <h1>That page does not exist here.</h1>
    <p class="suggest">Try one of these:</p>
    <ul>
      <li><a href="/">Home</a></li>
      <li><a href="/work">Work</a></li>
      <li><a href="/about">About</a></li>
    </ul>
  </section>
</Base>

<style>
  .wrap {
    max-width: 32rem;
  }
  .code {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 0 0 1rem 0;
    letter-spacing: 0.1em;
  }
  h1 {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    margin: 0 0 2rem 0;
    line-height: 1.2;
  }
  .suggest {
    color: var(--color-text-muted);
    margin: 0 0 0.75rem 0;
  }
  ul {
    list-style: none;
    padding: 0;
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.9375rem;
    display: grid;
    gap: 0.375rem;
  }
</style>
