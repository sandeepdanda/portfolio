---
import Base from "../layouts/Base.astro";

const jobs = [
  {
    role: "Software Development Engineer",
    company: "Amazon",
    url: "https://aws.amazon.com/",
    years: "Apr 2025 – present",
    location: "Seattle, WA",
    tags: ["Java", "TypeScript", "React", "AWS CDK", "CloudWatch"],
  },
  {
    role: "Business Technology Analyst",
    company: "Deloitte",
    url: "https://www2.deloitte.com/",
    years: "Jun 2021 – Dec 2022",
    location: "Hyderabad, India",
    tags: ["Salesforce", "Apex", "SOQL", "Lightning", "Admin"],
  },
  {
    role: "Assistant Software Engineer",
    company: "Nucleus Software",
    url: "https://www.nucleussoftware.com/",
    years: "Aug 2020 – Jun 2021",
    location: "Noida, India",
    tags: ["Java", "Spring Boot", "Oracle"],
  },
];
---

<Base
  title="Experience"
  description="Where I have worked so far."
>
  <section class="hero">
    <h1>Where I <em>worked</em></h1>
    <p class="subtitle">Every job so far has convinced me that the people around me know what they are doing. It is still hard to believe I am one of them.</p>
  </section>

  <ul class="cards">
    {jobs.map((j) => (
      <li>
        <a class="card" href={j.url} target="_blank" rel="noopener noreferrer">
          <span class="card-top">
            <span class="label">{j.role}</span>
            <span class="arrow" aria-hidden="true">↗</span>
          </span>
          <span class="headline">{j.company}</span>
          <span class="meta">
            <span>{j.years}</span>
            <span aria-hidden="true">·</span>
            <span>{j.location}</span>
          </span>
          {j.tags.length > 0 && (
            <ul class="tags">
              {j.tags.map((t) => <li>{t}</li>)}
            </ul>
          )}
        </a>
      </li>
    ))}
  </ul>
</Base>

<style>
  .hero { margin: 0 0 4rem 0; }
  h1 {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 7vw, 5rem);
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 0.95;
    margin: 0;
  }
  h1 em {
    font-style: italic;
    font-weight: 400;
    color: var(--color-accent);
  }
  .subtitle {
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    max-width: 34rem;
    margin: 1.25rem 0 0 0;
  }

  .cards {
    list-style: none;
    padding: 0;
    margin: 0;
    max-width: 52rem;
    display: grid;
    gap: 1rem;
  }
  .cards li { display: flex; }

  .card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    width: 100%;
    padding: 1.5rem 1.5rem 1.75rem 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    color: var(--color-text);
    text-decoration: none;
    transition:
      transform 200ms ease-out,
      border-color 200ms ease-out,
      box-shadow 200ms ease-out;
  }
  .card:hover {
    transform: translateY(-2px);
    border-color: var(--color-accent);
    box-shadow: 0 4px 24px -12px var(--color-accent);
  }
  .card:hover .arrow { transform: translate(3px, -3px); color: var(--color-accent); }
  .card:hover .headline { color: var(--color-accent); }

  .card-top {
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }
  .label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-text-muted);
  }
  .arrow {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 1rem;
    color: var(--color-text-muted);
    transition: transform 200ms ease-out, color 200ms ease-out;
  }
  .headline {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 500;
    letter-spacing: -0.015em;
    line-height: 1.1;
    color: var(--color-text);
    transition: color 150ms ease-out;
  }
  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }
  .tags {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }
  .tags li {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    padding: 0.25rem 0.625rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
  }
</style>
