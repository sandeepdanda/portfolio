---
import Base from "../layouts/Base.astro";

const jobs = [
  {
    role: "Software Development Engineer",
    company: "Amazon",
    url: "https://aws.amazon.com/",
    years: "Apr 2025 – present",
    location: "Seattle, WA",
    tags: ["Java", "TypeScript", "React", "AWS CDK", "CloudWatch"],
  },
  {
    role: "Business Technology Analyst",
    company: "Deloitte",
    url: "https://www2.deloitte.com/",
    years: "Jun 2021 – Dec 2022",
    location: "Hyderabad, India",
    tags: ["Salesforce", "Apex", "SOQL", "Lightning", "Admin"],
  },
  {
    role: "Assistant Software Engineer",
    company: "Nucleus Software",
    url: "https://www.nucleussoftware.com/",
    years: "Aug 2020 – Jun 2021",
    location: "Noida, India",
    tags: ["Java", "Spring Boot", "Oracle"],
  },
];
---

<Base
  title="Experience"
  description="Where I have worked so far."
>
  <section class="hero">
    <h1>Where I have <em>worked</em></h1>
    <p class="subtitle">Every job so far has convinced me that the people around me know what they are doing. It is still hard to believe I am one of them.</p>
  </section>

  <ul class="timeline">
    {jobs.map((j) => (
      <li>
        <div class="row">
          <div class="left">
            <p class="role">{j.role}</p>
            <a href={j.url} target="_blank" rel="noopener noreferrer" class="company">
              {j.company}
            </a>
          </div>
          <div class="right">
            <span>{j.years}</span>
            <span>{j.location}</span>
          </div>
        </div>
        <ul class="tags">
          {j.tags.map((t) => <li>{t}</li>)}
        </ul>
      </li>
    ))}
  </ul>
</Base>

<style>
  .hero {
    margin: 0 0 4rem 0;
  }
  .kicker {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-muted);
    margin: 0 0 1.5rem 0;
  }
  h1 {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 7vw, 5rem);
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 0.95;
    margin: 0;
  }
  h1 em {
    font-style: italic;
    font-weight: 400;
    color: var(--color-accent);
  }
  .subtitle {
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    max-width: 34rem;
    margin: 1.25rem 0 0 0;
  }

  .timeline {
    list-style: none;
    padding: 0;
    margin: 0;
    max-width: 48rem;
  }
  .timeline > li {
    padding: 2rem 0;
    border-bottom: 1px solid var(--color-border);
  }
  .timeline > li:last-child {
    border-bottom: none;
  }
  .row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2rem;
    align-items: baseline;
  }
  @media (max-width: 640px) {
    .row {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
  }
  .left {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .role {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-muted);
    margin: 0;
  }
  .company {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 500;
    letter-spacing: -0.015em;
    color: var(--color-text);
    text-decoration: none;
    line-height: 1.15;
  }
  .company:hover {
    color: var(--color-accent);
  }
  .right {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    text-align: right;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    white-space: nowrap;
  }
  @media (max-width: 640px) {
    .right {
      text-align: left;
      flex-direction: row;
      flex-wrap: wrap;
      gap: 0.5rem;
    }
  }

  .tags {
    list-style: none;
    padding: 0;
    margin: 1.25rem 0 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .tags li {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    padding: 0.25rem 0.625rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
  }
</style>
