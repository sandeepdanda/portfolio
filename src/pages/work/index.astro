---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import { readingTime, year } from "../../lib/content";

const entries = (await getCollection("work", (e) => e.data.status !== "draft"))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
---

<Base
  title="Work"
  description="Deep writeups on systems I built or broke."
>
  <section class="header">
    <h1>Work</h1>
    <p>Deep writeups on systems I built or broke.</p>
  </section>

  {entries.length === 0 ? (
    <p class="empty">Nothing here yet. Check back soon.</p>
  ) : (
    <ul class="list">
      {entries.map((entry) => {
        const minutes = readingTime(entry.body ?? "");
        return (
          <li>
            <a href={`/work/${entry.id}`} class="item-link">
              <h2>{entry.data.title}</h2>
              <p class="summary">{entry.data.summary}</p>
              <p class="meta">
                <span>{year(entry.data.publishedAt)}</span>
                {entry.data.tags.length > 0 && (
                  <>
                    <span class="sep">·</span>
                    <span>{entry.data.tags.join(", ")}</span>
                  </>
                )}
                <span class="sep">·</span>
                <span>{minutes} min read</span>
              </p>
            </a>
          </li>
        );
      })}
    </ul>
  )}
</Base>

<style>
  .header {
    margin-bottom: 3rem;
  }
  h1 {
    font-size: clamp(2.25rem, 5vw, 3rem);
    margin: 0 0 0.75rem 0;
  }
  .header p {
    color: var(--color-text-muted);
    font-size: 1.125rem;
    max-width: 34rem;
  }
  .empty {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.9375rem;
  }
  .list {
    list-style: none;
    padding: 0;
    margin: 0;
    max-width: 44rem;
  }
  .list li {
    border-bottom: 1px solid var(--color-border);
  }
  .item-link {
    display: block;
    padding: 1.5rem 0;
    color: inherit;
  }
  .item-link:hover h2 {
    color: var(--color-accent);
  }
  .item-link h2 {
    font-size: 1.5rem;
    margin: 0 0 0.5rem 0;
    color: var(--color-text);
    transition: color 150ms ease-out;
  }
  .summary {
    color: var(--color-text-muted);
    line-height: 1.55;
    margin: 0 0 0.625rem 0;
  }
  .meta {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin: 0;
  }
  .meta .sep {
    margin: 0 0.5rem;
    opacity: 0.5;
  }
</style>
