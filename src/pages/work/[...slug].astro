---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";
import { formatDate, readingTime, year } from "../../lib/content";

export async function getStaticPaths() {
  const entries = await getCollection("work", (e) => e.data.status !== "draft");
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { data } = entry;
const minutes = readingTime(entry.body ?? "");
---

<Base title={data.title} description={data.summary}>
  <article class="case-study">
    <header class="case-header">
      <p class="eyebrow">Case study</p>
      <h1>{data.title}</h1>
      <p class="subtitle">{data.summary}</p>
      <p class="meta">
        <span>{year(data.publishedAt)}</span>
        <span class="sep">·</span>
        <span>{minutes} min read</span>
        {data.tags.length > 0 && (
          <>
            <span class="sep">·</span>
            <span>{data.tags.join(", ")}</span>
          </>
        )}
      </p>
    </header>

    <div class="summary-box">
      <dl>
        <dt>Status</dt>
        <dd>{data.status}</dd>
        <dt>Published</dt>
        <dd>{formatDate(data.publishedAt)}</dd>
        {data.updatedAt && (
          <>
            <dt>Updated</dt>
            <dd>{formatDate(data.updatedAt)}</dd>
          </>
        )}
        {data.repo && (
          <>
            <dt>Repo</dt>
            <dd><a href={data.repo}>{data.repo.replace(/^https?:\/\//, "")}</a></dd>
          </>
        )}
        {data.live && (
          <>
            <dt>Live</dt>
            <dd><a href={data.live}>{data.live.replace(/^https?:\/\//, "")}</a></dd>
          </>
        )}
      </dl>
    </div>

    <div class="prose">
      <Content />
    </div>

    <footer class="case-footer">
      <a href="/work">← More case studies</a>
    </footer>
  </article>
</Base>

<style>
  .case-study {
    max-width: 44rem;
  }
  .case-header {
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }
  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    margin: 0 0 0.75rem 0;
  }
  h1 {
    font-size: clamp(2rem, 4.5vw, 2.75rem);
    margin: 0 0 1rem 0;
    line-height: 1.1;
  }
  .subtitle {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    line-height: 1.55;
    margin: 0 0 1rem 0;
  }
  .meta {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin: 0;
  }
  .meta .sep {
    margin: 0 0.5rem;
    opacity: 0.5;
  }

  .summary-box {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 1.25rem 1.5rem;
    margin-bottom: 2.5rem;
  }
  dl {
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 0.5rem 1.25rem;
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.875rem;
  }
  dt {
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.75rem;
    align-self: center;
  }
  dd {
    margin: 0;
    color: var(--color-text);
  }

  .prose :global(h2) {
    font-size: 1.625rem;
    margin: 2.5rem 0 1rem 0;
    line-height: 1.25;
  }
  .prose :global(h3) {
    font-size: 1.25rem;
    margin: 2rem 0 0.75rem 0;
  }
  .prose :global(p) {
    font-size: 1.0625rem;
    line-height: 1.7;
    margin: 0 0 1.25rem 0;
  }
  .prose :global(ul),
  .prose :global(ol) {
    font-size: 1.0625rem;
    line-height: 1.7;
    margin: 0 0 1.25rem 0;
    padding-left: 1.5rem;
  }
  .prose :global(li) {
    margin-bottom: 0.5rem;
  }
  .prose :global(blockquote) {
    border-left: 2px solid var(--color-border);
    padding: 0 0 0 1rem;
    color: var(--color-text-muted);
    margin: 1.5rem 0;
    font-style: italic;
  }
  .prose :global(code) {
    background: var(--color-surface);
    padding: 0.125rem 0.375rem;
    border-radius: 3px;
    font-size: 0.9em;
    border: 1px solid var(--color-border);
  }
  .prose :global(pre) {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 1rem;
    overflow-x: auto;
    font-size: 0.875rem;
    line-height: 1.5;
    margin: 1.5rem 0;
  }
  .prose :global(pre code) {
    background: transparent;
    border: none;
    padding: 0;
  }
  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }

  .case-footer {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
    font-family: var(--font-mono);
    font-size: 0.875rem;
  }
</style>
