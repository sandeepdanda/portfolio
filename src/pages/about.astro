---
import Base from "../layouts/Base.astro";
import { SOCIAL } from "../config";
---

<Base
  title="About"
  description="A software engineer in Seattle. Here is the longer version."
>
  <section class="hero">
    <p class="kicker">About</p>
    <h1>The longer <em>version</em>.</h1>
  </section>

  <div class="bio">
    <p>
      I am a software engineer in Seattle. I work at Amazon on distributed
      backend systems - the kind of problems that show up when data has to
      move reliably between places at scale.
    </p>
    <p>
      Before that I was at Deloitte and Nucleus Software in India, building
      financial and banking systems in Java and Spring. I did my masters at
      the University at Buffalo and my undergrad at NIT Durgapur.
    </p>
    <p>
      Outside of work I build small things. A movie recommendation app that
      does semantic search without calling out to an LLM, and a vocabulary
      RPG for people who read too much. I read more than I probably should.
    </p>
  </div>

  <section class="links-section">
    <h2>Links</h2>
    <ul class="links">
      <li><span class="label">Email</span> <a href={SOCIAL.email}>{SOCIAL.email.replace("mailto:", "")}</a></li>
      <li><span class="label">GitHub</span> <a href={SOCIAL.github} target="_blank" rel="noopener noreferrer">{SOCIAL.github.replace(/^https?:\/\//, "")}</a></li>
      <li><span class="label">LinkedIn</span> <a href={SOCIAL.linkedin} target="_blank" rel="noopener noreferrer">{SOCIAL.linkedin.replace(/^https?:\/\//, "")}</a></li>
      <li><span class="label">Resume</span> <a href="/resume.pdf">resume.pdf</a></li>
    </ul>
  </section>
</Base>

<style>
  .hero {
    margin: 1.5rem 0 4rem 0;
  }
  .kicker {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-muted);
    margin: 0 0 1.5rem 0;
  }
  h1 {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 7vw, 5rem);
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 0.95;
    margin: 0;
  }
  h1 em {
    font-style: italic;
    font-weight: 400;
    color: var(--color-accent);
  }

  .bio {
    max-width: 38rem;
    margin-bottom: 4rem;
  }
  .bio p {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-text);
    margin: 0 0 1.25rem 0;
  }
  .bio p:last-child {
    margin-bottom: 0;
  }

  .links-section {
    max-width: 38rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }
  .links-section h2 {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-text-muted);
    margin: 0 0 1.25rem 0;
  }
  .links {
    list-style: none;
    padding: 0;
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.9375rem;
    display: grid;
    gap: 0.5rem;
  }
  .links li {
    display: grid;
    grid-template-columns: 5.5rem 1fr;
    align-items: baseline;
  }
  .label {
    color: var(--color-text-muted);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
</style>
